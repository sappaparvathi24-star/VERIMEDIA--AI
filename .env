# ═══════════════════════════════════════════════
# VeriMedia AI — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# ── AI ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://verimedia:password@db:5432/verimedia

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────
SECRET_KEY=change-me-minimum-32-chars-in-production!!
API_KEY_SALT=another-salt-value-here

# ── Storage (MinIO / AWS S3) ─────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=verimedia-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ── App ──────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ── ML ───────────────────────────────────────────
ML_MODEL_PATH=./models
EMBEDDING_DIM=512

# ── Frontend ─────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_VERSION=v23
