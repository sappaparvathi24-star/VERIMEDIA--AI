"""VeriMedia — Health API"""
import os, time
from fastapi import APIRouter
from app.models.schemas import HealthResponse
from app.api.detection import _total_scans

router = APIRouter()
_start = time.monotonic()


@router.get("/health", response_model=HealthResponse)
async def health():
    return HealthResponse(
        status="operational",
        version="v23",
        services={
            "api": "operational",
            "claude_ai": "enabled" if os.getenv("ANTHROPIC_API_KEY") else "no_key (fallback mode)",
            "database": "operational",
        },
        uptime_seconds=round(time.monotonic() - _start, 1),
        total_scans=_total_scans,
    )
