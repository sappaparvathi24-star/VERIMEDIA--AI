"""VeriMedia — SQLAlchemy ORM Models"""
import os
import uuid
from datetime import datetime
from sqlalchemy import Column, String, Float, Boolean, Integer, DateTime, Text, JSON
from sqlalchemy.dialects.postgresql import UUID
from sqlalchemy.ext.asyncio import AsyncSession, create_async_engine
from sqlalchemy.orm import DeclarativeBase, sessionmaker

DATABASE_URL = os.getenv(
    "DATABASE_URL",
    "postgresql+asyncpg://verimedia:password@localhost:5432/verimedia",
).replace("postgresql://", "postgresql+asyncpg://")

engine = create_async_engine(DATABASE_URL, echo=False, pool_pre_ping=True, pool_size=10)
AsyncSessionLocal = sessionmaker(engine, class_=AsyncSession, expire_on_commit=False)


class Base(DeclarativeBase):
    pass


class DetectionJob(Base):
    __tablename__ = "detection_jobs"

    id = Column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    platform = Column(String(60), nullable=False, index=True)
    username = Column(String(100), nullable=False, index=True)
    caption = Column(Text, default="")
    content_type = Column(String(30), default="unknown")
    scenario = Column(String(30), nullable=True)
    similarity = Column(Float, nullable=True)
    fingerprint_hash = Column(String(64), nullable=True)
    ml_label = Column(String(20), nullable=True)
    ml_confidence = Column(Float, nullable=True)
    manipulation_probability = Column(Float, nullable=True)
    integrity_score = Column(Float, nullable=True)
    integrity_flags = Column(JSON, default=list)
    trust_score = Column(Float, nullable=True)
    risk_tier = Column(String(20), nullable=True)
    decision = Column(String(40), nullable=True, index=True)
    severity = Column(String(10), nullable=True)
    risk_label = Column(String(20), nullable=True)
    ai_confidence = Column(Float, nullable=True)
    reasoning_points = Column(JSON, default=list)
    action = Column(Text, nullable=True)
    dmca_needed = Column(Boolean, default=False)
    origin_traced = Column(Boolean, default=False)
    ai_source = Column(String(20), default="fallback")
    processing_ms = Column(Float, nullable=True)
    case_id = Column(String(30), nullable=True, index=True)
    created_at = Column(DateTime, default=datetime.utcnow, index=True)


class AssetRegistry(Base):
    __tablename__ = "asset_registry"

    id = Column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    asset_id = Column(String(64), unique=True, nullable=False, index=True)
    owner = Column(String(200), nullable=False)
    content_type = Column(String(30), default="unknown")
    fingerprint_hash = Column(String(64), nullable=True)
    watermark_hash = Column(String(128), nullable=True)
    watermark_iv = Column(String(64), nullable=True)
    asset_metadata = Column(JSON, default=dict)
    registered_at = Column(DateTime, default=datetime.utcnow)


class EnforcementCase(Base):
    __tablename__ = "enforcement_cases"

    id = Column(UUID(as_uuid=True), primary_key=True, default=uuid.uuid4)
    case_id = Column(String(30), unique=True, nullable=False, index=True)
    detection_job_id = Column(UUID(as_uuid=True), nullable=True)
    platform = Column(String(60), nullable=False)
    username = Column(String(100), nullable=False)
    severity = Column(String(10), nullable=False)
    decision = Column(String(40), nullable=False)
    content_type = Column(String(30), default="unknown")
    similarity = Column(Float, nullable=True)
    ml_label = Column(String(20), nullable=True)
    status = Column(String(30), default="open", index=True)
    dmca_filed = Column(Boolean, default=False)
    dmca_notice_json = Column(JSON, nullable=True)
    notes = Column(Text, nullable=True)
    created_at = Column(DateTime, default=datetime.utcnow, index=True)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)


async def init_db():
    async with engine.begin() as conn:
        try:
            from sqlalchemy import text
            await conn.execute(text("CREATE EXTENSION IF NOT EXISTS vector"))
        except Exception:
            pass
        await conn.run_sync(Base.metadata.create_all)


async def get_db():
    async with AsyncSessionLocal() as session:
        try:
            yield session
            await session.commit()
        except Exception:
            await session.rollback()
            raise
        finally:
            await session.close()
