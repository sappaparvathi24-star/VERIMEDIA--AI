async def generate_dmca(
    case_id: str, platform: str, username: str,
    caption: str, content_type: str, analysis: dict[str, Any],
) -> dict[str, Any]:
    sim_pct = int((analysis.get("similarity", 0.8)) * 100)
    ml_label = analysis.get("ml_label", "TAMPERED")
    ml_conf = int(analysis.get("ml_confidence", 0.85) * 100)
    int_score = int((analysis.get("integrity_score", 0.3)) * 100)
    decision = analysis.get("decision", "TAKEDOWN")
    severity = analysis.get("severity", "HIGH")

    prompt = f"""Generate a formal DMCA takedown notice as VeriMedia AI's legal enforcement engine.

CASE: {case_id} | Platform: {platform} | Account: @{username}
Content Type: {content_type} | Decision: {decision} | Severity: {severity}
Caption: "{caption}"
Evidence: {sim_pct}% visual match · ML: {ml_label} ({ml_conf}% confidence) · Integrity: {int_score}%

Return ONLY valid JSON:
{{"subject":"...","body":"full formal DMCA notice (plain text, no markdown, 300-500 words)","evidence_summary":"2-3 sentence summary of evidence","action_recommendation":"numbered 3-step action plan"}}"""

    try:
        client = get_client()
        msg = await client.messages.create(
            model="claude-sonnet-4-20250514",
            max_tokens=900,
            messages=[{"role": "user", "content": prompt}],
        )
        raw = msg.content[0].text.strip().lstrip("```json").lstrip("```").rstrip("```").strip()
        data = json.loads(raw)
        data.update({"source": "claude", "case_id": case_id,
                     "original_asset_id": f"vm-{case_id}", "match_score": sim_pct})
        return data
    except Exception as exc:
        logger.warning(f"Claude DMCA generation failed: {exc}")
        return _fallback_dmca(case_id, platform, username, caption, content_type, analysis)


def _fallback_dmca(
    case_id: str, platform: str, username: str,
    caption: str, ct: str, analysis: dict[str, Any],
) -> dict[str, Any]:
    sim_pct = int((analysis.get("similarity", 0.8)) * 100)
    ml_label = analysis.get("ml_label", "TAMPERED")
    ml_conf = int(analysis.get("ml_confidence", 0.85) * 100)
    int_score = int((analysis.get("integrity_score", 0.3)) * 100)
    decision = analysis.get("decision", "TAKEDOWN")
    severity = analysis.get("severity", "HIGH")

    body = (
        f"Dear {platform} Trust & Safety Team,\n\n"
        f"Pursuant to the Digital Millennium Copyright Act, 17 U.S.C. § 512(c), VeriMedia AI Rights "
        f"Management hereby formally requests the immediate removal of infringing content identified below.\n\n"
        f"CASE IDENTIFICATION\n"
        f"Case ID: {case_id}\n"
        f"Platform: {platform}\n"
        f"Infringing Account: @{username}\n"
        f"Content Type: {ct}\n"
        f"Caption: \"{caption}\"\n"
        f"Detection Timestamp: [UTC timestamp]\n\n"
        f"EVIDENCE OF INFRINGEMENT\n"
        f"• Visual Similarity: {sim_pct}% match to registered asset (ID: vm-{case_id})\n"
        f"• ML Classification: {ml_label} at {ml_conf}% confidence\n"
        f"• Content Integrity Score: {int_score}% (manipulation confirmed)\n"
        f"• Enforcement Decision: {decision} | Severity: {severity}\n"
        f"• AES-256 Watermark: Verified in original registered asset\n"
        f"• Evidence Package: frame_comparison_{case_id}.png, heatmap_{case_id}.png\n\n"
        f"LEGAL DECLARATION\n"
        f"I have a good faith belief that the use of the copyrighted material described above "
        f"is not authorized by the copyright owner, its agent, or the law. I declare under penalty "
        f"of perjury that this information is accurate and that I am authorized to act on behalf "
        f"of the exclusive rights holder.\n\n"
        f"Respectfully submitted,\n"
        f"[Authorized Rights Holder]\n"
        f"VeriMedia AI Rights Management\n"
        f"legal@verimedia.ai"
    )

    return {
        "case_id": case_id,
        "subject": f"DMCA Copyright Infringement Notice — Case {case_id} — {platform}",
        "body": body,
        "evidence_summary": (
            f"Unauthorized {ct} content detected on {platform} by account @{username} "
            f"with {sim_pct}% visual match to registered asset (vm-{case_id}). "
            f"ML classifier returned {ml_label} at {ml_conf}% confidence with integrity "
            f"score of {int_score}%, confirming significant content manipulation."
        ),
        "action_recommendation": (
            f"1. Submit notice to {platform} legal/trust-safety immediately via official DMCA portal.\n"
            f"2. Monitor for re-uploads and mirror content within 24 hours.\n"
            f"3. Preserve evidence package and escalate to legal counsel if unresolved in 48 hours."
        ),
        "original_asset_id": f"vm-{case_id}",
        "match_score": sim_pct,
        "source": "fallback",
    }
