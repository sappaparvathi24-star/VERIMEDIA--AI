# Signals that need to be inverted (high raw value = good)
_INVERTED = {"edge_consistency", "metadata_coherence", "watermark_presence"}

# (flag_label, threshold for raising flag)
_FLAG_DEFS: dict[str, tuple[str, float]] = {
    "jpeg_artifact":     ("JPEG artifact anomaly",        0.30),
    "noise_pattern":     ("Noise pattern mismatch",       0.30),
    "edge_consistency":  ("Edge inconsistency",           0.50),  # inverted
    "metadata_coherence":("Metadata stripped/tampered",   0.50),  # inverted
    "color_histogram":   ("Color histogram shift",        0.40),
    "face_landmark":     ("Face landmark distortion",     0.60),
    "lipsync":           ("Lip-sync mismatch",            0.65),
    "temporal_mismatch": ("Temporal inconsistency",       0.40),
    "watermark_presence":("Watermark absent/damaged",     0.50),  # inverted
}


def analyze_integrity(scenario: str, seed: int = 0) -> IntegrityResult:
    """Run 9-signal integrity analysis. Returns score 0–1 (1 = clean)."""
    profile = _INTEGRITY_PROFILES.get(scenario, _INTEGRITY_PROFILES["manipulated"])
    rng = random.Random(seed ^ hash(scenario))

    def jitter(v: float) -> float:
        return max(0.0, min(1.0, v + rng.uniform(-0.05, 0.05)))

    sigs = {k: jitter(v) for k, v in profile.items()}

    # Composite integrity score (1 = perfectly clean)
    score_parts = []
    for k, v in sigs.items():
        score_parts.append(1.0 - v if k not in _INVERTED else v)
    integrity_score = round(sum(score_parts) / len(score_parts), 4)

    # Collect flags
    flags: list[str] = []
    for sig_key, (flag_label, threshold) in _FLAG_DEFS.items():
        val = sigs[sig_key]
        anomaly = (1.0 - val) if sig_key in _INVERTED else val
        if anomaly > threshold:
            flags.append(flag_label)

    return IntegrityResult(
        score=integrity_score,
        flags=flags,
        signals=IntegritySignals(**sigs),
    )


