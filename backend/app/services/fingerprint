def compute_propagation(scenario: str, total_scans: int, seed: int = 0) -> PropagationSignal:
    rng = random.Random(seed ^ hash(scenario))

    if scenario in ("normal", "education"):
        velocity = rng.uniform(0.08, 0.25)
        urgency = "low"
        indicator = "organic fan share"
        ppm = round(rng.uniform(0.5, 8.0), 1)
        anomaly = False
        anomaly_score = round(rng.uniform(0.01, 0.15), 3)
    elif scenario in ("deepfake", "adversarial"):
        velocity = rng.uniform(0.82, 0.99)
        urgency = "critical"
        indicator = "⚡ viral AI-generated content detected"
        ppm = round(rng.uniform(80.0, 200.0), 1)
        anomaly = True
        anomaly_score = round(rng.uniform(0.85, 0.99), 3)
    elif scenario in ("manipulated", "scam"):
        velocity = rng.uniform(0.60, 0.82)
        urgency = "high"
        indicator = "rapid unauthorized spread detected"
        ppm = round(rng.uniform(25.0, 80.0), 1)
        anomaly = velocity > 0.70
        anomaly_score = round(rng.uniform(0.55, 0.80), 3)
    elif scenario == "news":
        velocity = rng.uniform(0.45, 0.68)
        urgency = "medium"
        indicator = "news cycle amplification"
        ppm = round(rng.uniform(12.0, 40.0), 1)
        anomaly = False
        anomaly_score = round(rng.uniform(0.20, 0.45), 3)
    else:
        velocity = rng.uniform(0.28, 0.55)
        urgency = "medium"
        indicator = "moderate propagation"
        ppm = round(rng.uniform(5.0, 25.0), 1)
        anomaly = False
        anomaly_score = round(rng.uniform(0.15, 0.40), 3)

    return PropagationSignal(
        total_scans=total_scans,
        velocity=round(velocity, 4),
        urgency=urgency,
        indicator=indicator,
        ppm=ppm,
        anomaly_flag=anomaly,
        anomaly_score=anomaly_score,
    )
