# PERCEPTUAL FINGERPRINT
# ══════════════════════════════════════════════════════════════

def compute_fingerprint(media_b64: str | None = None, seed: str = "") -> str:
    """
    Compute a perceptual fingerprint hash.
    Production: use imagehash.phash(PIL.Image.open(...))
    """
    if media_b64:
        return hashlib.sha256(media_b64.encode()).hexdigest()[:16]
    return hashlib.md5((seed or "vm-asset").encode()).hexdigest()[:16]


