def compute_authorship(
    similarity: float, integrity_score: float, scenario: str, seed: int = 0
) -> AuthorshipConfidence:
    rng = random.Random(seed ^ hash(scenario))

    if scenario in ("normal", "education"):
        conf = rng.uniform(0.94, 0.99)
        reason = "Watermark intact · high similarity · no manipulation signals"
        node = "Node #01"
        emb_dist = round(rng.uniform(0.01, 0.05), 4)
    elif scenario == "deepfake":
        conf = rng.uniform(0.38, 0.55)
        reason = "AI synthesis detected · origin uncertain · face landmarks distorted"
        node = "Node #???"
        emb_dist = round(rng.uniform(0.45, 0.65), 4)
    elif scenario == "adversarial":
        conf = rng.uniform(0.30, 0.50)
        reason = "Adversarial perturbation detected · fingerprint severely degraded"
        node = "Node #???"
        emb_dist = round(rng.uniform(0.50, 0.70), 4)
    elif integrity_score < 0.35:
        conf = rng.uniform(0.60, 0.75)
        reason = "Heavy manipulation — partial origin match via cosine distance"
        node = "Node #03"
        emb_dist = round(rng.uniform(0.30, 0.45), 4)
    elif similarity > 0.80:
        conf = rng.uniform(0.88, 0.97)
        reason = "Origin traced via cosine distance · high similarity confirmed"
        node = "Node #01"
        emb_dist = round(rng.uniform(0.05, 0.15), 4)
    else:
        conf = rng.uniform(0.72, 0.88)
        reason = "Origin traced with moderate confidence · some modification detected"
        node = "Node #02"
        emb_dist = round(rng.uniform(0.15, 0.35), 4)

    return AuthorshipConfidence(
        confidence=round(conf, 4),
        reason=reason,
        origin_node=node,
        embedding_distance=emb_dist,
    )


